# Tracker configuration
# The tracker is a client-side script — configuration is set via window.__trailscript_config
# at embed time, not via environment variables. This file is kept for documentation.
#
# Example embed config:
#   window.__trailscript_config = {
#     ingestionUrl: 'https://ingest.trailscript.com',
#     siteKey: 'sk_...'
#   };
